# Copy this file to .env for local development.
# Never commit .env to git.

# ── GCP ───────────────────────────────────────────────────────────────────────
# Set this in your shell profile, NOT in application code.
# Local dev:  export GOOGLE_APPLICATION_CREDENTIALS="$HOME/.config/gcp/kube-mind-dev.json"
# CI:         injected as a secret
# GKE prod:   use Workload Identity (no key file needed)
GOOGLE_APPLICATION_CREDENTIALS=

GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# ── LLM ───────────────────────────────────────────────────────────────────────
GEMINI_MODEL_ID=gemini-2.5-pro

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DEDUPLICATION_TTL_SECONDS=300

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION=k8s_incidents
QDRANT_SIMILARITY_THRESHOLD=0.95

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_DEFAULT_REPO_OWNER=
GITHUB_DEFAULT_REPO_NAME=
GITHUB_DEFAULT_BASE_BRANCH=main

# ── Slack ─────────────────────────────────────────────────────────────────────
# Leave empty to disable Slack notifications
SLACK_WEBHOOK_URL=

# ── Server ────────────────────────────────────────────────────────────────────
GRPC_PORT=50051
HTTP_PORT=5081

# mTLS (leave empty to use insecure mode for local dev)
GRPC_TLS_CA_CERT=
GRPC_TLS_SERVER_CERT=
GRPC_TLS_SERVER_KEY=

# ── Cluster identity ──────────────────────────────────────────────────────────
DEFAULT_CLUSTER_ID=default-cluster

# ── Observability ─────────────────────────────────────────────────────────────
# Leave empty to export traces to console only
OTLP_ENDPOINT=
LOG_LEVEL=INFO
